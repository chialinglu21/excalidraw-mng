      "link": null,
      "locked": false,
      "text": "被反對時\n聽取原因即可\n不過度解讀",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "被反對時\n聽取原因即可\n不過度解讀",
      "autoResize": false,
      "lineHeight": 1.35
    },
    {
      "id": "S3twXTx_TrsoByN2Y8Lgr",
      "type": "text",
